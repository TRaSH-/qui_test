          },
          {
            "field": "CATEGORY",
            "operator": "EQUAL",
            "value": "cross-seed"
          },
          {
            "field": "ADDED_ON",
            "operator": "LESS_THAN_OR_EQUAL",
            "value": "3600"
          },
          {
            "field": "PROGRESS",
            "operator": "LESS_THAN_OR_EQUAL",
            "value": "0.9"
          }
        ],
        "operator": "AND"
      },
      "enabled": true
    },
    "schemaVersion": "1"
  },
  "intervalSeconds": 3600,
  "name": "Force recheck: stopped cross-seeds (< 90%)",
